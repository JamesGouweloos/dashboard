rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Users collection: users can read/write their own profile
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Companies collection: authenticated users can read, all can write (for now)
    match /companies/{companyId} {
      allow read, write: if isAuthenticated();
    }
    
    // Agency config: authenticated users can read/write
    match /agency_config/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Revenue config: authenticated users can read/write
    match /revenue_config/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Dashboard data: authenticated users can read/write
    match /dashboard/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Occupancy data: authenticated users can read/write
    match /occupancy/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    // All other collections: authenticated users can read/write
    // This covers guests, fishing, game-sightings, etc.
    match /{collection}/{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}